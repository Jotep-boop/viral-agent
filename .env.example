# ── OpenRouter (LLM) ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ── ElevenLabs (TTS) ────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=CwhRBWXzGAHq8TQ4Fs17

# ── Pexels (stock footage) ──────────────────────────────────────────────────
PEXELS_API_KEY=...

# ── fal.ai (AI video generation) ────────────────────────────────────────────
# Get your key at https://fal.ai/dashboard/keys
FAL_KEY=...
# Optional: swap model (default is Kling v1.6 standard)
# FALAI_MODEL=fal-ai/kling-video/v2.1/standard/text-to-video

# ── YouTube Data API v3 ─────────────────────────────────────────────────────
# Create OAuth credentials at https://console.cloud.google.com/
# Download as client_secrets.json and place in this folder
YOUTUBE_CLIENT_SECRETS=client_secrets.json
# API key (separate from OAuth) — used to fetch trending videos as topic candidates
YOUTUBE_API_KEY=...

# ── Pipeline settings ───────────────────────────────────────────────────────
OUTPUT_DIR=output
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
MAX_VIDEO_DURATION=60
WHISPER_MODEL=base
